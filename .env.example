# Misma base de datos que usa el backend principal de DocYa (con tablas en su
# propio schema "contabilidad", aisladas del resto).
DATABASE_URL=postgresql://usuario:password@host/docya

# Mismo secreto y algoritmo que firma el docya_token en el backend principal.
# Copialo de las variables de entorno de ese servicio (no lo escribas a mano).
JWT_SECRET=
JWT_ALGORITHM=HS256

# Origenes permitidos para CORS, separados por coma.
CORS_ORIGINS=https://www.docya.online,https://docya.online,http://localhost:3000
